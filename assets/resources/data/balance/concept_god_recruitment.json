{
    "_meta":  {
                  "status":  "已定稿",
                  "version":  "v0.69",
                  "description":  "概念神通过累计招募GOAT触发下一次招募保底。",
                  "baseGoatRequirement":  100,
                  "maximumLineupConceptGodCount":  12
              },
    "formula":  {
                    "lockedX":  "conceptGodCountInLineupAtCycleStart + 1",
                    "requiredGoatResults":  "100 * lockedX",
                    "counterIncrementCondition":  "recruitedQuality == GOAT",
                    "guaranteeTrigger":  "goatCounter \u003e= requiredGoatResults",
                    "guaranteedResultTiming":  "next_recruit_after_threshold",
                    "counterResetTiming":  "after_guaranteed_concept_god_result_is_resolved"
                },
    "rules":  {
                  "lockXAtCycleStart":  true,
                  "lineupChangesDoNotAlterCurrentCycleThreshold":  true,
                  "paidRecruitGoatCounts":  true,
                  "freeAdRecruitGoatCounts":  true,
                  "thresholdGoatCardIsGrantedNormally":  true,
                  "guaranteedConceptGodDoesNotCountAsGoat":  true,
                  "normalRecruitCostOrFreeMethodStillApplies":  true,
                  "affectedByNormalQualityWeights":  false,
                  "affectedByScoutingDirector":  false,
                  "drawPool":  "data/concept_god_pool.json",
                  "drawMethod":  "equal_weight_among_eligible_concept_gods",
                  "excludeSameConceptGodCurrentlyInLineup":  true,
                  "dismissedConceptGodCanReappear":  true,
                  "resultHandling":  "compare_with_lowest_ovr_then_lineup_or_dismiss",
                  "inventoryEnabled":  false,
                  "counterActiveWhen":  "GOAT quality is recruitable at current market value level",
                  "guaranteedConceptGodRecruitGrantsWillpower":  true,
                  "willpowerReward":  10
              },
    "frontend":  {
                     "progressText":  "概念神保底：{goatCounter}/{requiredGoatResults}张GOAT",
                     "showLockedX":  true,
                     "showGuaranteeReadyState":  true,
                     "visibleWhen":  "GOAT quality is recruitable"
                 },
